NODE_ENV=production
PORT=4000
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

APP_NAME=AI Legal Search Yemen
DEFAULT_JURISDICTION=اليمن

JWT_SECRET=change-me-super-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
APP_ENCRYPTION_KEY=replace-with-long-random-secret
ADMIN_EMAIL=admin@legal.local
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=System Admin

DATA_DIR=./backend/data
UPLOAD_DIR=./backend/uploads

# Optional AI provider (OpenAI-compatible)
AI_API_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Optional Supabase Storage
USE_SUPABASE_STORAGE=true
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=legal-documents

# Legacy optional values kept for compatibility
REDIS_URL=
QUEUE_CONCURRENCY=5
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
